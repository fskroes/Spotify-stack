# private fleet overlay (targets kept local, not committed)
fleet/repos.local.yaml

# Locally compiled prose for private fleet targets. Public knowledge/*.md stays trackable.
knowledge/private/

# live state of currently-running tasks: one file per process, deleted when the
# run appends its ledger line. Machine-local and worthless a second later.
fleet/inflight/

# per-run model-usage evidence written by local runs. Machine-local and may hold
# real transcript-derived usage; never commit it into the public repo.
fleet/evidence/

# local Claude Code session config (personal/machine-local; the fleet injects its
# own .claude/ into sandboxes from agent-config/ at run time)
.claude/
.gstack/
